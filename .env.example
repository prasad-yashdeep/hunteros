# ─── LLM / STT / TTS ─────────────────────────────────────────────────
# Used by backend/voice.py to transcribe audio → text
OPENAI_API_KEY=sk-...

# Used by `sag` CLI to synthesize speech via ElevenLabs
ELEVENLABS_API_KEY=...

# Optional — any valid ElevenLabs voice name (default: "Harry")
HUNTEROS_TTS_VOICE=Harry

# ─── Server ──────────────────────────────────────────────────────────
# Port to bind FastAPI (default 7777)
# HUNTEROS_PORT=7777
